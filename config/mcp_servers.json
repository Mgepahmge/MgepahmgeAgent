{
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${WORKSPACE_DIR}"
      ],
      "description": "本地文件系统读写"
    },
    "mail": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-mail-server"
      ],
      "env": {
        "EMAIL_USER": "${EMAIL_USER}",
        "EMAIL_PASS": "${EMAIL_PASS}",
        "SMTP_HOST": "${SMTP_HOST}",
        "SMTP_PORT": "${SMTP_PORT}",
        "SMTP_SECURE": "${SMTP_SECURE}",
        "IMAP_HOST": "${IMAP_HOST}",
        "IMAP_PORT": "${IMAP_PORT}",
        "IMAP_SECURE": "${IMAP_SECURE}"
      },
      "description": "发送邮件通知"
    },
    "tavily-mcp": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "DEFAULT_PARAMETERS": "{\"include_images\": true, \"max_results\": 15, \"search_depth\": \"advanced\"}"
      }
    }
  },
  "注释": [
    "command 支持：npx / uvx / python / 任意可执行文件",
    "args 中的 ${VAR} 会被 .env 中的同名变量替换",
    "新增自定义 MCP Server：照此格式添加即可",
    "示例 - 自定义工业数据库 Server：",
    "  'industrial_db': {",
    "    'command': 'python',",
    "    'args': ['./mcp_servers/industrial_db.py']",
    "  }"
  ]
}
