# ============================================================
#  Agent 配置文件 - 复制为 .env 并填写
# ============================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# 可选：用本地模型替代 Claude（Ollama）
# OLLAMA_BASE_URL=http://localhost:11434
# LOCAL_MODEL=qwen2.5:14b

# --- RAG / PostgreSQL + pgvector ---
# 若不使用 RAG，留空即可，Agent 会自动跳过
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_kb
POSTGRES_USER=agent
POSTGRES_PASSWORD=change_me
VECTOR_TABLE=documents

# --- Embedding 模型 ---
# 本地 CUDA 加速，无需 API Key
# 模型会在首次运行时自动下载到 ~/.cache/huggingface/
EMBEDDING_MODEL=BAAI/bge-m3
# 强制 CPU（如果不需要 CUDA）: cpu
EMBEDDING_DEVICE=cuda

# --- Web Search ---
# DuckDuckGo 无需 Key（默认启用）
# 可选：Brave Search（效果更好）
# BRAVE_API_KEY=your-brave-key

# --- MCP Servers ---
# 逗号分隔的 MCP server 配置路径
MCP_CONFIG_PATH=./config/mcp_servers.json

# --- 工作目录 ---
# Agent 可读写的根目录，不要设为 /
WORKSPACE_DIR=~/workspace

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
