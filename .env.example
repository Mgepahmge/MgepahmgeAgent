# ============================================================
#  Agent 配置文件 - 复制为 .env 并填写
#  注意：API Key 不在此处配置，见下方"密钥管理"说明
# ============================================================

# --- RAG / PostgreSQL + pgvector ---
# 若不使用 RAG，留空即可，Agent 会自动跳过
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_kb
POSTGRES_USER=agent
POSTGRES_PASSWORD=change_me
VECTOR_TABLE=documents

# --- Embedding 模型 ---
# 本地 CUDA 加速，无需 API Key
# 首次运行从 HF_ENDPOINT 下载，之后自动离线加载（跳过网络检查）
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
# 模型缓存路径，留空则默认存到 data/models/（随项目持久化，不会被系统清理）
# EMBEDDING_CACHE_DIR=/root/agent/data/models

# --- Web Search ---
# DuckDuckGo lite 无需 Key（默认启用）
# 可选：Brave Search（效果更好，申请地址 https://api.search.brave.com/）
# BRAVE_API_KEY=

# --- HuggingFace 镜像（国内必填）---
HF_ENDPOINT=https://hf-mirror.com

# --- MCP Servers ---
MCP_CONFIG_PATH=./config/mcp_servers.json

# --- 工作目录 ---
# workspace 是 Agent 与宿主机交换文件的接口目录
# 建议挂载宿主机目录：incus config device add agent workspace disk source=/home/你的用户/workspace path=/workspace
WORKSPACE_DIR=/workspace

# --- 长期记忆自动提取 ---
# 默认关闭。开启后每隔 N 条消息自动用 LLM 提取记忆，会额外消耗 token。
# 建议手动通过 Agent 工具（memory_save）管理记忆，更精准可控。
# AUTO_EXTRACT_MEMORY=false

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# ============================================================
#  密钥管理说明
#  API Key 存放在容器外的宿主机，通过 incus 环境变量注入：
#
#  1. 在宿主机创建密钥文件（仅当前用户可读）：
#     mkdir -p ~/.config/agent
#     chmod 700 ~/.config/agent
#     cat > ~/.config/agent/secrets.env << 'SECRETS'
#     PROVIDER_KEY_CLAUDE=sk-ant-...
#     PROVIDER_KEY_OPENAI=sk-...
#     PROVIDER_KEY_DEEPSEEK=sk-...
#     PROVIDER_KEY_DOUBAO=...
#     SECRETS
#     chmod 600 ~/.config/agent/secrets.env
#
#  2. 注入到容器（每次修改密钥后重新执行）：
#     source ~/.config/agent/secrets.env
#     incus config set agent environment.PROVIDER_KEY_CLAUDE "$PROVIDER_KEY_CLAUDE"
#     incus config set agent environment.PROVIDER_KEY_OPENAI "$PROVIDER_KEY_OPENAI"
#     incus config set agent environment.PROVIDER_KEY_DEEPSEEK "$PROVIDER_KEY_DEEPSEEK"
#     incus config set agent environment.PROVIDER_KEY_DOUBAO "$PROVIDER_KEY_DOUBAO"
#
#  3. 重启容器使环境变量生效：
#     incus restart agent
#
#  providers.json 中用 api_key_env 字段引用变量名，不存明文 Key。
# ============================================================
